# Server
PORT=4000
NODE_ENV=development

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/nexclean

# Auth
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=30d

# OTP
OTP_EXPIRY_MIN=5
# Demo code that always works in development (remove in production)
DEMO_OTP=123456

# CORS — frontend origin(s). Comma-separate multiple (e.g. prod + preview URLs).
# Trailing slashes are tolerated. Use "*" to allow any origin (not for prod).
CLIENT_ORIGIN=http://localhost:5173

# Firebase Cloud Messaging (optional).
# Base64-encode your service-account JSON: base64 -i serviceAccount.json
# When unset, push notifications run in mock mode (logged to the server console).
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Razorpay (optional). Get test keys from dashboard.razorpay.com.
# When unset, payments run in mock mode (no real charge, booking still created).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Demo admin login (seeded on startup)
ADMIN_EMAIL=admin@nexclean.com
ADMIN_PASSWORD=admin123
