# Server
PORT=4000
NODE_ENV=development

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/nexclean

# Auth
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=30d

# OTP
OTP_EXPIRY_MIN=5
# Demo code that always works in development (remove in production)
DEMO_OTP=123456

# CORS (frontend origin)
CLIENT_ORIGIN=http://localhost:5173
